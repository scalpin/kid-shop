{
  "name": "my-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "db:up": "docker compose -f docker-compose.local.yml up -d db",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "db:migrate": "node scripts/db-migrate.cjs",
    "db:seed": "node scripts/db-seed.cjs",
    "db:reset": "node scripts/db-reset.cjs",
    "db:clear:products": "node scripts/db-clear-products.cjs",
    "db:clear:products:yes": "node scripts/db-clear-products.cjs --yes",
    "db:export:products": "node scripts/db-export-products.cjs",
    "db:import:products": "node scripts/db-import-products.cjs",
    "db:import:products:dry-run": "node scripts/db-import-products.cjs --dry-run",
    "db:import:products:replace": "node scripts/db-import-products.cjs --yes",
    "prod:push-products": "node scripts/prod-push-products.cjs",
    "prod:push-products:yes": "node scripts/prod-push-products.cjs --yes",
    "admin:hash-password": "node scripts/admin-password-hash.cjs"
  },
  "dependencies": {
    "next": "15.5.4",
    "pg": "^8.22.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13"
  }
}
